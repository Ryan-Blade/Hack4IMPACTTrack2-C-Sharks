{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "python main.py --api --buildings 50",
    "healthcheckPath": "/api/health",
    "healthcheckPort": 8000,
    "restartPolicyType": "ON_FAILURE"
  }
}
